# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/

# QVPIC Core - Never commit real secrets or large generated files
configs/default.yaml          # Contains Twilio + other credentials
*.env
.env.*
secrets/
credentials/

# Runtime / Generated files (large or sensitive)
checkpoints/
snapshots/
outputs/
logs/
models/
*.pt
*.gguf
chat_history.json
identity_structure.json

# === NEW: Identity & Fact files (user-controlled, often contain PII) ===
facts/
identity/
scripts/*_facts.txt
scripts/agent_private.md
scripts/agent_public.md
scripts/private_facts.txt
scripts/public_facts.txt

# Temporary / backup files
*.backup.*
*.tmp
temp.md
temp.py
temp_*.py
*.swp
*.swo

# Coverage and test artifacts
.coverage
coverage.xml
htmlcov/
.coverage.*
.pytest_cache/

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
